{
  "expo": {
    "name": "Sainik + Amrit",
    "slug": "truck-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "truckapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.margesh.sainikamrit"
    },
    "android": {
      "package": "com.margesh.sainikamrit",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#0D3B38",
          "dark": {
            "backgroundColor": "#0D3B38"
          }
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": ["./assets/images/notification-icon.png"],
          "largeIcons": ["./assets/images/notification-icon-large.png"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1cf03f47-66d4-4ea2-a6c5-0bb687ec15a8"
      }
    },
    "owner": "xyder"
  }
}
